generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Tier {
  FREE
  PRO
}

enum Role {
  USER
  ADMIN
}

enum TradeSide {
  BUY
  SELL
}

enum TradeStatus {
  PENDING
  FILLED
  CANCELLED
  FAILED
}

enum TradeMode {
  PAPER
  LIVE
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime?
  passwordHash    String?
  name            String?
  image           String?
  tier            Tier      @default(PRO)
  role            Role      @default(USER)
  stripeCustomerId String?
  alpacaApiKey    String?
  alpacaSecretKey String?
  alpacaPaper     Boolean   @default(true)
  bannedUntil         DateTime?
  apiCallCount        Int       @default(0)
  apiCallWindow       DateTime  @default(now())
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  searchHistory   SearchHistory[]
  portfolios      Portfolio[]
  alerts          Alert[]
  watchlistItems  WatchlistItem[]
  accounts        Account[]
  sessions        Session[]
  autoTrades      AutoTrade[]
  tradingConfig   TradingConfig?
  activityLogs    ActivityLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SearchHistory {
  id           String   @id @default(cuid())
  userId       String
  ticker       String
  companyName  String?
  sector       String?
  verdict      String?
  analysisJson String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model Portfolio {
  id        String   @id @default(cuid())
  userId    String
  name      String
  cash      Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings PortfolioHolding[]
  trades   Trade[]
}

model PortfolioHolding {
  id           String   @id @default(cuid())
  portfolioId  String
  ticker       String
  shares       Float
  avgCostBasis Float
  addedAt      DateTime @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, ticker])
}

model Trade {
  id            String      @id @default(cuid())
  portfolioId   String
  ticker        String
  side          TradeSide
  qty           Float
  price         Float?
  alpacaOrderId String?
  status        TradeStatus @default(PENDING)
  mode          TradeMode   @default(PAPER)
  signalSource  String?
  executedAt    DateTime?
  createdAt     DateTime    @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model Alert {
  id            String   @id @default(cuid())
  userId        String
  ticker        String?
  signalType    String
  condition     String
  threshold     Float?
  isActive      Boolean  @default(true)
  lastTriggered DateTime?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WatchlistItem {
  id      String   @id @default(cuid())
  userId  String
  ticker  String
  addedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
}

enum AutoTradeStatus {
  PENDING
  OPEN
  CLOSED
  CANCELLED
}

model AutoTrade {
  id            String          @id @default(cuid())
  userId        String
  ticker        String
  side          String
  qty           Float
  entryPrice    Float?
  exitPrice     Float?
  stopLoss      Float?
  takeProfit    Float?
  pnl           Float?
  strategy      String?
  aiConfidence  Float?
  signalScore   Float?
  alpacaOrderId String?
  status        AutoTradeStatus @default(PENDING)
  mode          TradeMode       @default(PAPER)
  exitReason    String?
  entryAt       DateTime?
  exitAt        DateTime?
  createdAt     DateTime        @default(now())

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshot TradeSnapshot?

  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, mode])
}

/// Rich feature vector captured at trade entry — the training data for the learning engine.
model TradeSnapshot {
  id              String   @id @default(cuid())
  autoTradeId     String   @unique
  autoTrade       AutoTrade @relation(fields: [autoTradeId], references: [id], onDelete: Cascade)

  // Signal sub-scores (8 dimensions from signals.ts)
  rsiScore        Float?
  macdScore       Float?
  bollingerScore  Float?
  trendScore      Float?
  volumeScore     Float?
  momentumScore   Float?
  vwapScore       Float?
  srScore         Float?
  compositeSignal Float?

  // Conviction sub-scores (7 dimensions from conviction.ts)
  cvTechnical     Float?
  cvFundamental   Float?
  cvValuation     Float?
  cvSmartMoney    Float?
  cvCatalyst      Float?
  cvRisk          Float?
  cvDiversity     Float?
  cvComposite     Float?
  dataConfidence  Float?

  // Market context at entry
  rsi             Float?
  atr             Float?
  volumeRatio     Float?
  fearGreed       Float?
  signalSource    String?
  discoveryReason String?
  strategy        String?
  sector          String?

  createdAt       DateTime @default(now())

  @@index([autoTradeId])
}

/// Aggregated performance stats per strategy / source / sector / conviction bucket.
model StrategyLedger {
  id            String   @id @default(cuid())
  userId        String
  period        String
  dimension     String
  trades        Int      @default(0)
  wins          Int      @default(0)
  totalPnl      Float    @default(0)
  avgPnl        Float    @default(0)
  winRate       Float    @default(0)
  avgHoldDays   Float    @default(0)
  updatedAt     DateTime @updatedAt

  @@unique([userId, period, dimension])
  @@index([userId, dimension])
}

/// Per-user learned weights that override hardcoded defaults, updated by recalibration.
model LearningWeights {
  id        String   @id @default(cuid())
  userId    String   @unique
  weights   Json
  version   Int      @default(1)
  updatedAt DateTime @updatedAt
}

model ConvictionPick {
  id              String    @id @default(cuid())
  ticker          String
  companyName     String?
  rank            Int
  conviction      Float
  dataConfidence  Float?
  targetPrice     Float
  currentPrice    Float
  holdPeriod      String
  holdLabel       String
  holdDays        Int?
  thesis          String
  signals         String[]
  sector          String?
  pickedAt        DateTime  @default(now())
  peakPrice       Float?
  latestPrice     Float?
  returnPct       Float?
  peakReturnPct   Float?
  lastTrackedAt   DateTime?
  hitTarget       Boolean   @default(false)
  hitTargetAt     DateTime?
  withinTimeline  Boolean?
  outcome         String?

  @@index([pickedAt(sort: Desc)])
  @@index([ticker, pickedAt(sort: Desc)])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  detail    String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model AppSettings {
  id                String  @id @default("global")
  proGateEnabled    Boolean @default(false)
  updatedAt         DateTime @updatedAt
}

model TradingConfig {
  id                String   @id @default(cuid())
  userId            String   @unique
  enabled           Boolean  @default(false)
  mode              TradeMode @default(PAPER)
  paperBalance      Float    @default(10000)
  maxPositionPct    Float    @default(5)
  maxDailyLossPct   Float    @default(3)
  maxOpenPositions  Int      @default(5)
  riskProfile       String   @default("MODERATE")
  weeklyTargetPct   Float    @default(10)
  watchlist         String[] @default(["AAPL", "MSFT", "NVDA", "GOOGL", "AMZN", "META", "TSLA", "AMD", "NFLX", "JPM", "BTC-USD", "ETH-USD", "SOL-USD"])
  /// Rolling suggestions (Top 10, discovery); merged into scan universe, max length enforced in app code
  recommendedTickers String[] @default([])
  strategies        String[] @default(["MOMENTUM", "MEAN_REVERSION", "SWING"])
  lastCronAt        DateTime?
  lastCronResult    String?
  lastCronTrades    Int      @default(0)
  lastCronSignals   Int      @default(0)
  cronRunCount      Int      @default(0)
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
